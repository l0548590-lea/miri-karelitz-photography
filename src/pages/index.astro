  <div style="max-width:900px;margin:0 auto;">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center;margin-bottom:40px;">

      <div>
        <img src="/logo.png" alt="מירי קרליץ" style="height:60px;width:auto;filter:brightness(2) invert(1);margin-bottom:14px;" />
        <p style="font-family:'Heebo',sans-serif;font-size:15px;color:rgba(255,255,255,.45);line-height:1.8;">
          "כשתמונה ורגש נפגשים,<br/>זה כבר סיפור אחר..."
        </p>
      </div>

      <div>
        <h4 style="font-family:'Heebo',sans-serif;font-weight:700;font-size:15px;color:var(--pink-mid);margin-bottom:18px;letter-spacing:1px;">יצירת קשר</h4>
        <div style="display:flex;flex-direction:column;gap:14px;">
          <a href="tel:0533190561" style="font-family:'Heebo',sans-serif;font-size:16px;font-weight:600;color:rgba(255,255,255,.7);text-decoration:none;transition:color .2s;display:flex;gap:10px;align-items:center;"
            onmouseover="this.style.color='#fff'" onmouseout="this.style.color='rgba(255,255,255,.7)'">
            <span style="background:var(--red);width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0;">📞</span>
            053-319-0561
          </a>
          <a href="mailto:mirizilum@gmail.com" style="font-family:'Heebo',sans-serif;font-size:16px;font-weight:600;color:rgba(255,255,255,.7);text-decoration:none;transition:color .2s;display:flex;gap:10px;align-items:center;"
            onmouseover="this.style.color='#fff'" onmouseout="this.style.color='rgba(255,255,255,.7)'">
            <span style="background:var(--red);width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0;">✉️</span>
            mirizilum@gmail.com
          </a>
        </div>
      </div>
    </div>

    <div style="border-top:1px solid rgba(255,255,255,.08);padding-top:22px;text-align:center;">
      <p style="font-family:'Heebo',sans-serif;font-size:13px;color:rgba(255,255,255,.22);">
        © {new Date().getFullYear()} מירי קרליץ | סיפור פוטוגני ♥ | כל הזכויות שמורות
      </p>
    </div>
  </div>
</footer>

<style>
  @media(max-width:640px){
    footer > div > div:first-child { grid-template-columns:1fr !important; }
  }
</style>

</Layout>

<script>
  // ─────────────────────────────────────────
  // NAVBAR scroll effect
  // ─────────────────────────────────────────
  const nav = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    if (!nav) return;
    if (window.scrollY > 60) {
      nav.style.background = 'rgba(255,255,255,.95)';
      nav.style.boxShadow  = '0 2px 20px rgba(196,30,58,.1)';
      nav.style.padding    = '12px 40px';
      nav.style.backdropFilter = 'blur(12px)';
    } else {
      nav.style.background = 'transparent';
      nav.style.boxShadow  = 'none';
      nav.style.padding    = '18px 40px';
    }
  }, { passive: true });

  // ─────────────────────────────────────────
  // FLOATING HEARTS in hero
  // ─────────────────────────────────────────
  const heroHearts = document.getElementById('hero-hearts');
  const heartChars = ['♥','♡','❤'];
  const pinkShades = ['#FFB3C6','#E8839A','#C41E3A','#FADADD','#FF6B8A'];

  function spawnHeart() {
    if (!heroHearts) return;
    const el = document.createElement('span');
    el.textContent = heartChars[Math.floor(Math.random()*3)];
    const size = 12 + Math.random()*22;
    const dur  = 7 + Math.random()*8;
    const left = Math.random()*100;
    const delay = Math.random()*4;
    el.className = 'fheart';
    el.style.cssText = `
      bottom:0; left:${left}%;
      font-size:${size}px;
      color:${pinkShades[Math.floor(Math.random()*pinkShades.length)]};
      animation-duration:${dur}s;
      animation-delay:${delay}s;
    `;
    heroHearts.appendChild(el);
    setTimeout(() => el.remove(), (dur + delay) * 1000);
  }
  for (let i = 0; i < 14; i++) spawnHeart();
  setInterval(spawnHeart, 1800);

  // ─────────────────────────────────────────
  // GALLERY TABS + STAGGER + LIGHTBOX
  // ─────────────────────────────────────────
  const tabs = document.querySelectorAll<HTMLButtonElement>('.gtab');

  function staggerGrid(grid: HTMLElement) {
    const items = grid.querySelectorAll<HTMLElement>('.gitem');
    items.forEach((item, i) => {
      item.classList.remove('in');
      setTimeout(() => item.classList.add('in'), i * 40);
    });
  }

  // Init first grid
  const firstGrid = document.getElementById('grid-bat-mitzva');
  if (firstGrid) setTimeout(() => staggerGrid(firstGrid), 200);

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.tab!;
      tabs.forEach(t => {
        t.style.background = 'transparent';
        t.style.color = 'var(--red)';
      });
      tab.style.background = 'var(--red)';
      tab.style.color = '#fff';

      document.querySelectorAll<HTMLElement>('.gallery-grid').forEach(g => {
        g.style.display = 'none';
      });
      const grid = document.getElementById(`grid-${target}`);
      if (grid) {
        grid.style.display = 'grid';
        staggerGrid(grid);
      }
    });
  });

  // Gallery hover effects
  document.querySelectorAll<HTMLElement>('.gitem').forEach(item => {
    const img     = item.querySelector('img') as HTMLImageElement;
    const overlay = item.querySelector('.img-overlay') as HTMLElement;
    const heart   = overlay?.querySelector('span') as HTMLElement;

    item.addEventListener('mouseenter', () => {
      if (img)     img.style.transform = 'scale(1.08)';
      if (overlay) overlay.style.background = 'rgba(196,30,58,.3)';
      if (heart)   { heart.style.opacity='1'; heart.style.transform='scale(1)'; }
    });
    item.addEventListener('mouseleave', () => {
      if (img)     img.style.transform = '';
      if (overlay) overlay.style.background = 'rgba(196,30,58,0)';
      if (heart)   { heart.style.opacity='0'; heart.style.transform='scale(.6)'; }
    });

    // Lightbox click
    item.addEventListener('click', () => {
      const cat  = item.dataset.cat!;
      const idx  = parseInt(item.dataset.idx!);
      const grid = document.getElementById(`grid-${cat}`);
      if (!grid) return;
      const imgs = Array.from(grid.querySelectorAll<HTMLImageElement>('.gitem img'))
                        .map(i => i.src);
      (window as any).openLB(imgs[idx], imgs, idx);
    });
  });

  // ─────────────────────────────────────────
  // TESTIMONIALS CAROUSEL (drag)
  // ─────────────────────────────────────────
  const track = document.getElementById('carousel-track') as HTMLElement;
  if (track) {
    let isDown = false, startX = 0, scrollLeft = 0;
    track.addEventListener('mousedown',  e => { isDown=true; startX=e.pageX-track.offsetLeft; scrollLeft=track.scrollLeft; track.style.transition='none'; });
    track.addEventListener('mouseleave', () => { isDown=false; });
    track.addEventListener('mouseup',    () => { isDown=false; track.style.transition=''; });
    track.addEventListener('mousemove',  e => {
      if (!isDown) return;
      e.preventDefault();
      const x = e.pageX - track.offsetLeft;
      track.scrollLeft = scrollLeft - (x - startX) * 1.4;
    });
    // Touch
    let tStartX = 0, tScrollLeft = 0;
    track.addEventListener('touchstart', e => { tStartX=e.touches[0].pageX; tScrollLeft=track.scrollLeft; }, { passive:true });
    track.addEventListener('touchmove',  e => {
      const dx = tStartX - e.touches[0].pageX;
      track.scrollLeft = tScrollLeft + dx;
    }, { passive:true });
    // Auto scroll
    let autoDir = 1;
    const autoScroll = () => {
      if (!isDown) {
        track.scrollLeft += autoDir;
        if (track.scrollLeft >= track.scrollWidth - track.clientWidth - 2) autoDir = -1;
        if (track.scrollLeft <= 0) autoDir = 1;
      }
      requestAnimationFrame(autoScroll);
    };
    setTimeout(autoScroll, 1000);
    // Make overflow scrollable
    track.style.overflowX = 'auto';
    track.style.scrollbarWidth = 'none';
    (track.style as any).msOverflowStyle = 'none';
    const style = document.createElement('style');
    style.textContent = '#carousel-track::-webkit-scrollbar{display:none}';
    document.head.appendChild(style);
  }

  // ─────────────────────────────────────────
  // CONTACT FORM (EmailJS)
  // ─────────────────────────────────────────
  const EMAILJS_PUBLIC_KEY         = 'YOUR_PUBLIC_KEY';
  const EMAILJS_SERVICE_ID         = 'YOUR_SERVICE_ID';
  const EMAILJS_TEMPLATE_NOTIFY    = 'YOUR_TEMPLATE_NOTIFY_ID';
  const EMAILJS_TEMPLATE_AUTOREPLY = 'YOUR_TEMPLATE_AUTOREPLY_ID';

  (window as any).emailjs?.init({ publicKey: EMAILJS_PUBLIC_KEY });

  const form       = document.getElementById('contact-form') as HTMLFormElement;
  const successMsg = document.getElementById('success-msg') as HTMLElement;
  const submitBtn  = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnText    = document.getElementById('btn-text') as HTMLElement;
  const btnLoading = document.getElementById('btn-loading') as HTMLElement;
  const formError  = document.getElementById('form-error') as HTMLElement;
  const formOpenTime = Date.now();

  const phoneRx = /^(\+972|0)(5[0-9]|[2-9][0-9]?)[\-\s]?\d{3}[\-\s]?\d{4}$/;
  const emailRx = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

  function showErr(id: string, show: boolean, msg = '') {
    const el = document.getElementById(`err-${id}`) as HTMLElement;
    const inp = document.getElementById(id) as HTMLInputElement;
    if (el) { el.style.display = show ? 'block' : 'none'; if (msg) el.textContent = `⚠ ${msg}`; }
    if (inp) inp.style.borderColor = show ? 'var(--red)' : '#F0D0D8';
  }
  function setLoading(v: boolean) {
    submitBtn.disabled = v;
    btnText.style.display    = v ? 'none'   : 'block';
    btnLoading.style.display = v ? 'flex'   : 'none';
  }

  function validate() {
    const name  = (document.getElementById('name')  as HTMLInputElement).value.trim();
    const phone = (document.getElementById('phone') as HTMLInputElement).value.trim();
    const email = (document.getElementById('email') as HTMLInputElement).value.trim();
    let ok = true;
    if (name.length < 2)              { showErr('name',  true, 'אנא הכניסי שם מלא');           ok=false; } else showErr('name',  false);
    if (!phoneRx.test(phone))         { showErr('phone', true, 'אנא הכניסי מספר טלפון תקין');   ok=false; } else showErr('phone', false);
    if (email && !emailRx.test(email)){ showErr('email', true, 'כתובת אימייל לא תקינה');       ok=false; } else showErr('email', false);
    return ok;
  }

  ['name','phone','email'].forEach(id =>
    document.getElementById(id)?.addEventListener('blur', validate));

  form?.addEventListener('submit', async e => {
    e.preventDefault();
    formError.style.display = 'none';

    const honeypot = (document.getElementById('honeypot') as HTMLInputElement).value;
    if (honeypot) return;
    if (Date.now() - formOpenTime < 2000) return;

    const lastSent = localStorage.getItem('mk_last_sent');
    if (lastSent && Date.now() - Number(lastSent) < 60_000) {
      formError.textContent = 'אנא המתיני דקה לפני שליחה נוספת';
      formError.style.display = 'block';
      return;
    }
    if (!validate()) return;

    const name    = (document.getElementById('name')    as HTMLInputElement).value.trim();
    const phone   = (document.getElementById('phone')   as HTMLInputElement).value.trim();
    const email   = (document.getElementById('email')   as HTMLInputElement).value.trim();
    const message = (document.getElementById('message') as HTMLTextAreaElement).value.trim();

    setLoading(true);
    try {
      const ejs = (window as any).emailjs;
      await ejs.send(EMAILJS_SERVICE_ID, EMAILJS_TEMPLATE_NOTIFY, {
        from_name: name, from_phone: phone, from_email: email||'לא סופק',
        message: message||'לא הוזנה הודעה', reply_to: email||'mirizilum@gmail.com',
      });
      if (email) {
        await ejs.send(EMAILJS_SERVICE_ID, EMAILJS_TEMPLATE_AUTOREPLY, {
          to_name: name, to_email: email,
        });
      }
      localStorage.setItem('mk_last_sent', String(Date.now()));
      form.style.display = 'none';
      successMsg.style.display = 'block';
    } catch(err) {
      console.error(err);
      formError.textContent = 'אירעה שגיאה בשליחה. אנא נסי שוב או צרי קשר בטלפון.';
      formError.style.display = 'block';
      setLoading(false);
    }
  });

  document.getElementById('reset-form-btn')?.addEventListener('click', () => {
    form.reset(); form.style.display='flex';
    successMsg.style.display='none'; setLoading(false);
    formError.style.display='none';
  });
</script>
