---
import Layout from '../layouts/Layout.astro';

const categories = [
  { id: 'bat-mitzva',  label: 'בת מצווה',       count: 14 },
  { id: 'mishpaha',    label: 'משפחה',            count: 33 },
  { id: 'gil-shana',  label: 'גיל שנה',          count: 17 },
  { id: 'halaka',     label: 'חלאקה',            count: 48 },
  { id: 'rosh-shana', label: 'ראש השנה',          count:  3 },
  { id: 'albums',     label: 'אלבומים',          count: 15 },
];

const makeImgs = (cat: string, label: string, n: number) =>
  Array.from({ length: n }, (_, i) => ({
    src: `/gallery/${cat}/${String(i+1).padStart(2,'0')}.jpg`,
    alt: label,
  }));

const galleryImages: Record<string, {src:string;alt:string}[]> = {
  'bat-mitzva': makeImgs('bat-mitzva','צילום בת מצווה',14),
  'mishpaha':   makeImgs('mishpaha',  'צילום משפחה',   33),
  'gil-shana':  makeImgs('gil-shana', 'גיל שנה',       17),
  'halaka':     makeImgs('halaka',    'חלאקה',         48),
  'rosh-shana': makeImgs('rosh-shana','ראש השנה',       3),
  'albums':     makeImgs('albums',    'אלבום',         15),
};

const testimonialsInitial = [
  { file:'המלצה_אסתי-_בת_מצווה.PNG',              name:'אסתי',           type:'בת מצווה' },
  { file:'המלצה_שושי_נתניא-_חלאקה.PNG',           name:'שושי נתניא',     type:'חלאקה' },
  { file:'המלצה_ריקי_דומב-_חלאקה.PNG',            name:'ריקי דומב',      type:'חלאקה' },
  { file:'המלצה_מזי_דניאל-_בת_מצווה.PNG',         name:'מזי דניאל',      type:'בת מצווה' },
  { file:'המלצה_ציפי_יעקובזון_-צילומי_גיל_שנה.PNG',name:'ציפי יעקובזון', type:'גיל שנה' },
];
const testimonialsExtra = [
  { file:'המלצה_אילה_אלישיוב_חלאקה+בר_מצווה.png', name:'אילה אלישיוב',   type:'חלאקה + בר מצווה' },
  { file:'המלצה_דסי_הרוש-_חלאקה.PNG',              name:'דסי הרוש',       type:'חלאקה' },
  { file:'המלצה_חיהלה_כהן_-חלאקה.PNG',             name:'חיהלה כהן',      type:'חלאקה' },
  { file:'המלצה_חלאקה.png',                         name:'לקוחה מרוצה',   type:'חלאקה' },
  { file:'המלצה_לאה_נ-_חלאקה.PNG',                 name:'לאה נ.',         type:'חלאקה' },
  { file:'המלצה_רחל_קליימן-_צילומי_רה.PNG',        name:'רחל קליימן',     type:'ראש השנה' },
  { file:'המלצה_שפרה_ליפשיץ.-_חלאקה.png',          name:'שפרה ליפשיץ',    type:'חלאקה' },
  { file:'המלצה-_אתי_ואמא_בת_מצווה.jpg',           name:'אתי',            type:'בת מצווה' },
  { file:'המלצה-_מלכי_רוט.PNG',                    name:'מלכי רוט',       type:'לקוחה' },
  { file:'המלצה-_מרתון_פורים.PNG',                 name:'מרתון פורים',    type:'אירוע' },
  { file:'המלצה-_צילומי_רה.PNG',                   name:'לקוחה',          type:'ראש השנה' },
  { file:'תגובה_ספונטנית_במייל_של_לקוחה.png',      name:'תגובה ספונטנית', type:'מייל' },
  { file:'תגובה_ספונטנית-_לאה_קוסובסקי-_שחור.PNG', name:'לאה קוסובסקי',   type:'תגובה ספונטנית' },
];
---

<Layout>

<!-- ═══════════════════════════════ NAVBAR ═══════════════════════════════ -->
<nav id="navbar" style="
  position:fixed; top:0; right:0; left:0; z-index:500;
  padding: 18px 40px;
  display:flex; align-items:center; justify-content:space-between;
  transition: background .35s, box-shadow .35s, padding .35s;
">
  <img src="/logo.png" alt="מירי קרליץ" style="height:52px; width:auto;" />
  <ul style="display:flex; gap:36px; list-style:none;" class="nav-links">
    <li><a href="#gallery"      class="nav-link">גלריה</a></li>
    <li><a href="#testimonials" class="nav-link">המלצות</a></li>
    <li><a href="#about"        class="nav-link">עליי</a></li>
    <li><a href="#contact"      class="nav-link">צור קשר</a></li>
  </ul>
  <a href="#contact" class="btn-ripple" style="
    background:var(--red); color:#fff;
    font-family:'Heebo',sans-serif; font-weight:700; font-size:15px;
    padding:11px 26px; border-radius:50px; text-decoration:none;
    box-shadow:0 4px 20px rgba(196,30,58,.35);
    transition: transform .2s, box-shadow .2s;
  " onmouseover="this.style.transform='scale(1.04)';this.style.boxShadow='0 6px 28px rgba(196,30,58,.45)'"
     onmouseout="this.style.transform='';this.style.boxShadow='0 4px 20px rgba(196,30,58,.35)'">
    רוצה לשמוע עוד ♥
  </a>
</nav>

<style>
  .nav-link {
    font-family:'Heebo',sans-serif; font-weight:600; font-size:16px;
    color:var(--text); text-decoration:none;
    position:relative; padding-bottom:4px;
    transition: color .2s;
  }
  .nav-link::after {
    content:''; position:absolute; bottom:0; right:0;
    width:0; height:2px; background:var(--red);
    transition: width .3s ease;
  }
  .nav-link:hover { color:var(--red); }
  .nav-link:hover::after { width:100%; }
  @media(max-width:768px){ .nav-links{ display:none; } }
</style>

<!-- ═══════════════════════════════ HERO ═══════════════════════════════ -->
<section id="hero" style="
  min-height:100vh;
  display:flex; flex-direction:column;
  align-items:center; justify-content:center;
  text-align:center;
  padding: 120px 24px 80px;
  position:relative; overflow:hidden;
  background: linear-gradient(145deg, #FFF0F3 0%, #FFE5EC 35%, #FADADD 65%, #FFF5F7 100%);
">
  <!-- Blob shapes -->
  <div style="position:absolute;inset:0;pointer-events:none;overflow:hidden;" aria-hidden="true">
    <div style="position:absolute;width:600px;height:600px;border-radius:50%;
      background:radial-gradient(circle,rgba(255,179,198,.45) 0%,transparent 70%);
      top:-150px; right:-150px; animation:blobPulse 8s ease-in-out infinite;"></div>
    <div style="position:absolute;width:500px;height:500px;border-radius:50%;
      background:radial-gradient(circle,rgba(197,220,240,.35) 0%,transparent 70%);
      bottom:-120px; left:-120px; animation:blobPulse 10s ease-in-out infinite reverse;"></div>
    <div style="position:absolute;width:300px;height:300px;border-radius:50%;
      background:radial-gradient(circle,rgba(232,131,154,.25) 0%,transparent 70%);
      top:40%; left:10%; animation:blobPulse 12s ease-in-out infinite 2s;"></div>
  </div>

  <!-- Floating hearts -->
  <div id="hero-hearts" style="position:absolute;inset:0;pointer-events:none;overflow:hidden;" aria-hidden="true"></div>

  <!-- Logo -->
  <div class="reveal d1" style="margin-bottom:32px; position:relative; z-index:1;">
    <img src="/logo.png" alt="מירי קרליץ" style="height:110px;width:auto;filter:drop-shadow(0 8px 24px rgba(196,30,58,.18));" />
  </div>

  <!-- Main heading -->
  <div class="reveal d2" style="position:relative;z-index:1;margin-bottom:16px;">
    <h1 id="hero-title" style="
      font-family:'Heebo',sans-serif;
      font-size:clamp(52px,9vw,110px);
      font-weight:900;
      line-height:1.05;
      color:var(--red);
      letter-spacing:-1px;
    ">סיפור פוטוגני</h1>
  </div>

  <!-- Quote -->
  <div class="reveal-blur d3" style="position:relative;z-index:1;max-width:560px;margin-bottom:40px;">
    <p style="
      font-family:'Heebo',sans-serif;
      font-size:clamp(18px,2.8vw,26px);
      font-weight:300;
      color:var(--dark);
      line-height:1.7;
    ">"כשתמונה ורגש נפגשים,<br/>זה כבר סיפור אחר..."</p>
  </div>

  <!-- Tags -->
  <div class="reveal d4" style="display:flex;gap:12px;flex-wrap:wrap;justify-content:center;margin-bottom:44px;position:relative;z-index:1;">
    {['בת מצווה','ילדים','משפחה','גיל שנה','חלאקה'].map(tag => (
      <span style="
        background:rgba(196,30,58,.08); border:1px solid rgba(196,30,58,.2);
        color:var(--red); font-family:'Heebo',sans-serif;
        font-weight:600; font-size:15px;
        padding:7px 18px; border-radius:50px;
      ">{tag}</span>
    ))}
  </div>

  <!-- CTA -->
  <div class="reveal-scale d5" style="position:relative;z-index:1;">
    <a href="#contact" class="btn-ripple" style="
      display:inline-block;
      background:var(--red); color:#fff;
      font-family:'Heebo',sans-serif; font-weight:800; font-size:19px;
      padding:16px 48px; border-radius:60px;
      text-decoration:none;
      box-shadow:0 8px 40px rgba(196,30,58,.4);
      transition:transform .25s, box-shadow .25s;
    " onmouseover="this.style.transform='translateY(-3px)';this.style.boxShadow='0 14px 50px rgba(196,30,58,.5)'"
       onmouseout="this.style.transform='';this.style.boxShadow='0 8px 40px rgba(196,30,58,.4)'">
      רוצה לשמוע עוד ♥
    </a>
  </div>

  <!-- Scroll cue -->
  <div style="position:absolute;bottom:36px;left:50%;transform:translateX(-50%);
    display:flex;flex-direction:column;align-items:center;gap:8px;
    color:var(--pink-deep);font-family:'Heebo',sans-serif;font-size:12px;font-weight:600;letter-spacing:2px;">
    <span>גלול למטה</span>
    <div style="width:1px;height:42px;background:linear-gradient(var(--pink-deep),transparent);animation:scrollBounce 2s ease-in-out infinite;"></div>
  </div>
</section>

<style>
  @keyframes blobPulse {
    0%,100%{ transform:scale(1) translate(0,0); }
    50%    { transform:scale(1.12) translate(15px,15px); }
  }
  @keyframes scrollBounce {
    0%,100%{ opacity:1;transform:scaleY(1); }
    50%    { opacity:.4;transform:scaleY(.6); }
  }
</style>

<!-- ═══════════════════════════════ MARQUEE ═══════════════════════════════ -->
<div style="background:var(--red);padding:14px 0;overflow:hidden;" aria-hidden="true">
  <div class="marquee-inner" style="font-family:'Heebo',sans-serif;font-weight:700;font-size:15px;color:rgba(255,255,255,.9);letter-spacing:2px;text-transform:uppercase;">
    {Array.from({length:12}).map(()=>(
      <span style="padding:0 32px;">✦ סיפור פוטוגני &nbsp;✦ בת מצווה &nbsp;✦ ילדים &nbsp;✦ משפחה &nbsp;✦ גיל שנה &nbsp;✦ חלאקה &nbsp;✦ ראש השנה</span>
    ))}
  </div>
</div>

<!-- ═══════════════════════════════ GALLERY ═══════════════════════════════ -->
<section id="gallery" style="padding:100px 32px;background:#fff;">
  <div style="max-width:1200px;margin:0 auto;">

    <!-- Header -->
    <div class="reveal" style="text-align:center;margin-bottom:60px;">
      <p style="font-family:'Heebo',sans-serif;font-weight:700;font-size:13px;letter-spacing:4px;color:var(--red);text-transform:uppercase;margin-bottom:12px;">הגלריה שלי</p>
      <h2 style="font-family:'Heebo',sans-serif;font-size:clamp(38px,5vw,64px);font-weight:900;color:var(--dark);line-height:1.1;">
        כל תמונה מספרת<br/><span style="color:var(--red);">סיפור משלה</span>
      </h2>
      <div style="width:48px;height:3px;background:var(--red);border-radius:3px;margin:20px auto 0;"></div>
    </div>

    <!-- Tabs -->
    <div id="gallery-tabs" class="reveal" style="display:flex;flex-wrap:wrap;justify-content:center;gap:10px;margin-bottom:44px;">
      {categories.map((cat,i)=>(
        <button data-tab={cat.id} class="gtab btn-ripple"
          style={`font-family:'Heebo',sans-serif;font-weight:700;font-size:15px;
          padding:10px 22px;border-radius:50px;cursor:pointer;border:2px solid var(--red);
          transition:all .25s;
          background:${i===0?'var(--red)':'transparent'};
          color:${i===0?'#fff':'var(--red)'};`}>
          {cat.label}
        </button>
      ))}
    </div>

    <!-- Grids -->
    {categories.map((cat)=>(
      <div id={`grid-${cat.id}`} class="gallery-grid"
        style={`display:${cat.id==='bat-mitzva'?'grid':'none'};
          grid-template-columns:${cat.id==='albums'
            ? 'repeat(auto-fill,minmax(220px,1fr))'
            : 'repeat(auto-fill,minmax(160px,1fr))'};
          gap:10px;`}>
        {galleryImages[cat.id].map((img,idx)=>(
          <div class="gitem" data-src={img.src} data-idx={idx} data-cat={cat.id}
            style={`position:relative;overflow:hidden;border-radius:12px;
              ${cat.id==='albums'?'background:#fff;padding:6px;':'aspect-ratio:1;background:var(--pink);'}
              cursor:pointer;`}>
            <img src={img.src} alt={img.alt} loading="lazy"
              style={`width:100%;${cat.id==='albums'?'height:auto;object-fit:contain;border-radius:8px;':'height:100%;object-fit:cover;'}
                display:block;
                transition:transform .5s cubic-bezier(.25,.46,.45,.94);`} />
            <div style="position:absolute;inset:0;background:rgba(196,30,58,0);
              display:flex;align-items:center;justify-content:center;
              transition:background .3s;" class="img-overlay">
              <span style="color:#fff;font-size:28px;opacity:0;transition:opacity .3s;transform:scale(.6);transition:opacity .3s,transform .3s;">♥</span>
            </div>
          </div>
        ))}
      </div>
    ))}
  </div>
</section>

<!-- ═══════════════════════════════ TESTIMONIALS ═══════════════════════════════ -->
<section id="testimonials" style="padding:100px 0;background:linear-gradient(180deg,var(--pink-light) 0%,var(--pink) 100%);overflow:hidden;">
  <div style="max-width:1200px;margin:0 auto;padding:0 32px;">

    <!-- Header -->
    <div class="reveal" style="text-align:center;margin-bottom:60px;">
      <p style="font-family:'Heebo',sans-serif;font-weight:700;font-size:13px;letter-spacing:4px;color:var(--red);text-transform:uppercase;margin-bottom:12px;">מה אומרות הלקוחות</p>
      <h2 style="font-family:'Heebo',sans-serif;font-size:clamp(38px,5vw,64px);font-weight:900;color:var(--dark);line-height:1.1;">
        המלצות <span style="color:var(--red);">מהלב</span>
      </h2>
      <div style="width:48px;height:3px;background:var(--red);border-radius:3px;margin:20px auto 0;"></div>
    </div>

  </div>

  <!-- Carousel -->
  <div style="position:relative;overflow:hidden;padding:8px 0 24px;">
    <div id="carousel-track" class="carousel-track" style="padding:0 40px;">
      {[...testimonialsInitial,...testimonialsExtra].map((t,i)=>(
        <div class="reveal" style={`transition-delay:${(i%5)*.08}s;`}>
          <div style="
            width:300px;
            background:#fff;
            border-radius:24px;
            overflow:hidden;
            box-shadow:0 4px 24px rgba(196,30,58,.1);
            border:1px solid rgba(196,30,58,.08);
            transition:transform .3s,box-shadow .3s;
          " onmouseover="this.style.transform='translateY(-6px)';this.style.boxShadow='0 16px 44px rgba(196,30,58,.18)'"
             onmouseout="this.style.transform='';this.style.boxShadow='0 4px 24px rgba(196,30,58,.1)'">
            <div style="background:linear-gradient(135deg,var(--red),var(--red-light));padding:16px 18px;display:flex;align-items:center;gap:12px;">
              <div style="width:36px;height:36px;border-radius:50%;background:rgba(255,255,255,.25);
                display:flex;align-items:center;justify-content:center;
                font-family:'Heebo',sans-serif;font-weight:800;font-size:16px;color:#fff;">{t.name[0]}</div>
              <div>
                <p style="font-family:'Heebo',sans-serif;font-weight:700;font-size:14px;color:#fff;">{t.name}</p>
                <p style="font-family:'Heebo',sans-serif;font-size:11px;color:rgba(255,255,255,.75);">{t.type}</p>
              </div>
              <span style="margin-right:auto;color:rgba(255,255,255,.7);font-size:18px;">♥</span>
            </div>
            <div style="padding:10px;">
              <img src={`/testimonials/${t.file}`} alt={`המלצה של ${t.name}`}
                style="width:100%;border-radius:12px;display:block;" loading="lazy" />
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Show more -->
  <div style="text-align:center;margin-top:36px;">
    <p style="font-family:'Heebo',sans-serif;font-size:15px;color:var(--muted);">
      גרור ימינה לעוד המלצות ♥
    </p>
  </div>
</section>

<!-- ═══════════════════════════════ ABOUT ═══════════════════════════════ -->
<section id="about" style="padding:100px 32px;background:#fff;overflow:hidden;">
  <div style="max-width:800px;margin:0 auto;">

    <!-- Text side -->
    <div style="display:flex;flex-direction:column;gap:28px;">
      <div class="reveal" style="text-align:center;">
        <p style="font-family:'Heebo',sans-serif;font-weight:700;font-size:13px;letter-spacing:4px;color:var(--red);text-transform:uppercase;margin-bottom:12px;">קצת עליי</p>
        <h2 style="font-family:'Heebo',sans-serif;font-size:clamp(34px,4.5vw,56px);font-weight:900;color:var(--dark);line-height:1.15;">
          מירי קרליץ —<br/><span style="color:var(--red);">הצלמת שלך</span>
        </h2>
        <div style="width:48px;height:3px;background:var(--red);border-radius:3px;margin:20px auto 0;"></div>
      </div>

      <div class="reveal d2" style="font-family:'Heebo',sans-serif;font-size:17px;font-weight:400;color:#6B4452;line-height:1.9;display:flex;flex-direction:column;gap:16px;text-align:center;">
        <p>שלום! אני מירי קרליץ, צלמת המתמחה בצילומי <strong style="color:var(--red);">בת מצווה, ילדים ומשפחה</strong>. אני מאמינה שכל משפחה היא יצירת אמנות בפני עצמה.</p>
        <p>הגישה שלי היא <strong style="color:var(--red);">חמה, סבלנית ויצירתית</strong> — לוקחת את הזמן להכיר את הילדים ולגרום להם להרגיש בנוח לפני שלוחצת על התריס.</p>
        <p>כל סשן מתוכנן בקפידה — מבחירת הלוקיישן, תיאום הביגוד, ועד עריכה סופית עם <strong style="color:var(--red);">לב שלם</strong>.</p>
      </div>

      <!-- Values -->
      <div class="reveal d3" style="display:grid;grid-template-columns:repeat(3,1fr);gap:14px;">
        {[
          { icon:'♥', t:'חום וסבלנות', d:'גישה אישית לכל ילד' },
          { icon:'✨', t:'מקצועיות',    d:'ציוד מתקדם ועריכה' },
          { icon:'📷', t:'יצירתיות',    d:'זוויות ייחודיות' },
        ].map(v=>(
          <div style="background:var(--pink-light);border-radius:18px;padding:18px 14px;text-align:center;
            border:1px solid rgba(196,30,58,.1);transition:border-color .2s,transform .2s;"
            onmouseover="this.style.borderColor='var(--red)';this.style.transform='translateY(-3px)'"
            onmouseout="this.style.borderColor='';this.style.transform=''">
            <div style="font-size:26px;margin-bottom:6px;">{v.icon}</div>
            <p style="font-family:'Heebo',sans-serif;font-weight:700;font-size:14px;color:var(--red);">{v.t}</p>
            <p style="font-family:'Heebo',sans-serif;font-size:12px;color:var(--muted);margin-top:4px;">{v.d}</p>
          </div>
        ))}
      </div>

      <div class="reveal d4" style="text-align:center;">
        <a href="#contact" class="btn-ripple" style="
          display:inline-block;background:var(--red);color:#fff;
          font-family:'Heebo',sans-serif;font-weight:700;font-size:17px;
          padding:14px 38px;border-radius:50px;text-decoration:none;
          box-shadow:0 6px 28px rgba(196,30,58,.35);
          transition:transform .2s,box-shadow .2s;"
          onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 10px 36px rgba(196,30,58,.45)'"
          onmouseout="this.style.transform='';this.style.boxShadow='0 6px 28px rgba(196,30,58,.35)'">
          בואו נכיר ♥
        </a>
      </div>
    </div>
  </div>
</section>

<!-- Responsive about on mobile -->
<style>
  @media(max-width:768px){
    #about > div { grid-template-columns:1fr !important; gap:48px !important; }
  }
</style>

<!-- ═══════════════════════════════ CONTACT ═══════════════════════════════ -->
<section id="contact" style="padding:100px 24px;position:relative;overflow:hidden;
  background:linear-gradient(145deg,#FFF0F3 0%,#FFE0EA 40%,#FADADD 100%);">

  <!-- Decorative blobs -->
  <div style="position:absolute;inset:0;pointer-events:none;" aria-hidden="true">
    <div style="position:absolute;width:400px;height:400px;border-radius:50%;
      background:radial-gradient(circle,rgba(196,30,58,.12) 0%,transparent 70%);
      top:-100px;right:-80px;"></div>
    <div style="position:absolute;width:350px;height:350px;border-radius:50%;
      background:radial-gradient(circle,rgba(197,220,240,.3) 0%,transparent 70%);
      bottom:-80px;left:-60px;"></div>
  </div>

  <div style="max-width:620px;margin:0 auto;position:relative;z-index:1;">

    <!-- Header -->
    <div class="reveal" style="text-align:center;margin-bottom:50px;">
      <p style="font-family:'Heebo',sans-serif;font-weight:700;font-size:13px;letter-spacing:4px;color:var(--red);text-transform:uppercase;margin-bottom:12px;">בואו נדבר</p>
      <h2 style="font-family:'Heebo',sans-serif;font-size:clamp(38px,5vw,64px);font-weight:900;color:var(--dark);line-height:1.1;">
        צור <span style="color:var(--red);">קשר</span>
      </h2>
      <p style="font-family:'Heebo',sans-serif;font-size:18px;color:var(--muted);margin-top:12px;">נשמח לשמוע ממכם ולתכנן ביחד את הסשן המושלם</p>
      <div style="width:48px;height:3px;background:var(--red);border-radius:3px;margin:20px auto 0;"></div>
    </div>

    <!-- Contact icons -->
    <div class="reveal d1" style="display:flex;justify-content:center;gap:28px;margin-bottom:40px;flex-wrap:wrap;">
      <a href="tel:0533190561" style="display:flex;align-items:center;gap:8px;font-family:'Heebo',sans-serif;font-weight:700;font-size:16px;color:var(--dark);text-decoration:none;transition:color .2s;"
        onmouseover="this.style.color='var(--red)'" onmouseout="this.style.color='var(--dark)'">
        <span style="background:var(--red);color:#fff;width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:15px;">📞</span>
        053-319-0561
      </a>
      <a href="mailto:mirizilum@gmail.com" style="display:flex;align-items:center;gap:8px;font-family:'Heebo',sans-serif;font-weight:700;font-size:16px;color:var(--dark);text-decoration:none;transition:color .2s;"
        onmouseover="this.style.color='var(--red)'" onmouseout="this.style.color='var(--dark)'">
        <span style="background:var(--red);color:#fff;width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:15px;">✉️</span>
        mirizilum@gmail.com
      </a>
    </div>

    <!-- Card -->
    <div class="reveal-scale d2" style="background:#fff;border-radius:28px;padding:44px 40px;box-shadow:0 20px 60px rgba(196,30,58,.12);border:1px solid rgba(196,30,58,.08);">

      <form id="contact-form" style="display:flex;flex-direction:column;gap:20px;">

        <!-- Honeypot -->
        <div style="display:none;" aria-hidden="true">
          <input type="text" name="website" id="honeypot" tabindex="-1" autocomplete="off" />
        </div>

        {[
          { id:'name',    label:'שם מלא',     type:'text',  placeholder:'הכניסי את שמך המלא',  required:true  },
          { id:'phone',   label:'טלפון',      type:'tel',   placeholder:'050-000-0000',          required:true  },
          { id:'email',   label:'אימייל',     type:'email', placeholder:'your@email.com',         required:false },
        ].map(f=>(
          <div style="display:flex;flex-direction:column;gap:6px;">
            <label for={f.id} style="font-family:'Heebo',sans-serif;font-weight:700;font-size:15px;color:var(--dark);">
              {f.label} {f.required ? <span style="color:var(--red);">*</span> : <span style="font-weight:400;font-size:13px;color:var(--muted);">(לקבלת אישור)</span>}
            </label>
            <input type={f.type} id={f.id} name={f.id} placeholder={f.placeholder}
              style="width:100%;background:#FAFAFA;border:1.5px solid #F0D0D8;border-radius:14px;
                padding:13px 18px;font-family:'Heebo',sans-serif;font-size:16px;color:var(--dark);
                transition:border-color .2s,box-shadow .2s;outline:none;"
              onfocus="this.style.borderColor='var(--red)';this.style.boxShadow='0 0 0 3px rgba(196,30,58,.12)'"
              onblur="this.style.borderColor='#F0D0D8';this.style.boxShadow=''" />
            <span id={`err-${f.id}`} style="display:none;font-family:'Heebo',sans-serif;font-size:13px;color:var(--red);">⚠ שגיאה בשדה</span>
          </div>
        ))}

        <div style="display:flex;flex-direction:column;gap:6px;">
          <label for="message" style="font-family:'Heebo',sans-serif;font-weight:700;font-size:15px;color:var(--dark);">סוג הצילום / הודעה</label>
          <textarea id="message" name="message" rows="3" placeholder="ספרי לי על האירוע שלך..."
            style="width:100%;background:#FAFAFA;border:1.5px solid #F0D0D8;border-radius:14px;
              padding:13px 18px;font-family:'Heebo',sans-serif;font-size:16px;color:var(--dark);
              resize:none;transition:border-color .2s,box-shadow .2s;outline:none;"
            onfocus="this.style.borderColor='var(--red)';this.style.boxShadow='0 0 0 3px rgba(196,30,58,.12)'"
            onblur="this.style.borderColor='#F0D0D8';this.style.boxShadow=''"></textarea>
        </div>

        <p id="form-error" style="display:none;font-family:'Heebo',sans-serif;font-size:14px;color:var(--red);text-align:center;
          background:rgba(196,30,58,.07);border-radius:10px;padding:10px;"></p>

        <button type="submit" id="submit-btn" class="btn-ripple" style="
          width:100%;background:var(--red);color:#fff;
          font-family:'Heebo',sans-serif;font-weight:800;font-size:18px;
          padding:16px;border-radius:16px;border:none;cursor:pointer;
          box-shadow:0 6px 30px rgba(196,30,58,.35);
          transition:transform .2s,box-shadow .2s;
          display:flex;align-items:center;justify-content:center;gap:10px;"
          onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 10px 40px rgba(196,30,58,.45)'"
          onmouseout="this.style.transform='';this.style.boxShadow='0 6px 30px rgba(196,30,58,.35)'">
          <span id="btn-text">שלחי לי הודעה ♥</span>
          <span id="btn-loading" style="display:none;align-items:center;gap:8px;">
            <svg style="animation:spin .8s linear infinite;width:20px;height:20px;" viewBox="0 0 24 24" fill="none">
              <circle cx="12" cy="12" r="10" stroke="rgba(255,255,255,.3)" stroke-width="3"/>
              <path d="M12 2a10 10 0 0 1 10 10" stroke="#fff" stroke-width="3" stroke-linecap="round"/>
            </svg>
            שולח...
          </span>
        </button>

      </form>

      <!-- Success -->
      <div id="success-msg" style="display:none;text-align:center;padding:40px 20px;">
        <div style="font-size:64px;animation:heartbeat 1.4s ease-in-out infinite;">♥</div>
        <h3 style="font-family:'Heebo',sans-serif;font-size:28px;font-weight:900;color:var(--dark);margin:16px 0 8px;">תודה! נחזור אליך בהקדם</h3>
        <p style="font-family:'Heebo',sans-serif;font-size:16px;color:var(--muted);line-height:1.7;">
          קיבלנו את פנייתך ונחזור אליך תוך 24 שעות.<br/>
          <span style="font-size:14px;">שלחנו לך מייל אישור לכתובת שהזנת</span>
        </p>
        <button id="reset-form-btn" style="margin-top:20px;background:none;border:none;cursor:pointer;
          font-family:'Heebo',sans-serif;font-size:14px;color:var(--muted);text-decoration:underline;">
          שליחת פנייה נוספת
        </button>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes spin { to { transform:rotate(360deg); } }
</style>

<!-- ═══════════════════════════════ FOOTER ═══════════════════════════════ -->
