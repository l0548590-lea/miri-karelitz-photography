---
import Layout from '../layouts/Layout.astro';

const categories = [
  { id: 'bat-mitzva',  label: 'בת מצווה',        count: 14 },
  { id: 'mishpaha',    label: 'משפחה',             count: 33 },
  { id: 'gil-shana',  label: 'גיל שנה',           count: 17 },
  { id: 'halaka',     label: 'חלאקה',             count: 48 },
  { id: 'rosh-shana', label: 'צילומי ראש השנה',   count: 3  },
  { id: 'albums',     label: 'אלבומים',           count: 15 },
];

const makeImgs = (cat: string, label: string, n: number) =>
  Array.from({ length: n }, (_, i) => ({
    src: `/gallery/${cat}/${String(i + 1).padStart(2, '0')}.jpg`,
    alt: label,
  }));

const galleryImages: Record<string, { src: string; alt: string }[]> = {
  'bat-mitzva': makeImgs('bat-mitzva', 'צילום בת מצווה',      14),
  'mishpaha':   makeImgs('mishpaha',   'צילום משפחה',          33),
  'gil-shana':  makeImgs('gil-shana',  'צילומי גיל שנה',       17),
  'halaka':     makeImgs('halaka',     'צילומי חלאקה',         48),
  'rosh-shana': makeImgs('rosh-shana', 'צילומי ראש השנה',       3),
  'albums':     makeImgs('albums',     'אלבום',                15),
};

const testimonialsInitial = [
  { file: 'המלצה_אסתי-_בת_מצווה.PNG',           name: 'אסתי', type: 'בת מצווה' },
  { file: 'המלצה_שושי_נתניא-_חלאקה.PNG',         name: 'שושי נתניא', type: 'חלאקה' },
  { file: 'המלצה_ריקי_דומב-_חלאקה.PNG',          name: 'ריקי דומב', type: 'חלאקה' },
  { file: 'המלצה_מזי_דניאל-_בת_מצווה.PNG',       name: 'מזי דניאל', type: 'בת מצווה' },
  { file: 'המלצה_ציפי_יעקובזון_-צילומי_גיל_שנה.PNG', name: 'ציפי יעקובזון', type: 'גיל שנה' },
];

const testimonialsExtra = [
  { file: 'המלצה_אילה_אלישיוב_חלאקה+בר_מצווה.png', name: 'אילה אלישיוב', type: 'חלאקה + בר מצווה' },
  { file: 'המלצה_דסי_הרוש-_חלאקה.PNG',             name: 'דסי הרוש', type: 'חלאקה' },
  { file: 'המלצה_חיהלה_כהן_-חלאקה.PNG',            name: 'חיהלה כהן', type: 'חלאקה' },
  { file: 'המלצה_חלאקה.png',                        name: 'לקוחה מרוצה', type: 'חלאקה' },
  { file: 'המלצה_לאה_נ-_חלאקה.PNG',               name: 'לאה נ.', type: 'חלאקה' },
  { file: 'המלצה_רחל_קליימן-_צילומי_רה.PNG',       name: 'רחל קליימן', type: 'ראש השנה' },
  { file: 'המלצה_שפרה_ליפשיץ.-_חלאקה.png',         name: 'שפרה ליפשיץ', type: 'חלאקה' },
  { file: 'המלצה-_אתי_ואמא_בת_מצווה.jpg',          name: 'אתי', type: 'בת מצווה' },
  { file: 'המלצה-_מלכי_רוט.PNG',                   name: 'מלכי רוט', type: 'לקוחה' },
  { file: 'המלצה-_מרתון_פורים.PNG',                name: 'מרתון פורים', type: 'אירוע' },
  { file: 'המלצה-_צילומי_רה.PNG',                  name: 'לקוחה', type: 'ראש השנה' },
  { file: 'תגובה_ספונטנית_במייל_של_לקוחה.png',    name: 'תגובה ספונטנית', type: 'מייל' },
  { file: 'תגובה_ספונטנית-_לאה_קוסובסקי-_שחור.PNG', name: 'לאה קוסובסקי', type: 'תגובה ספונטנית' },
];
---

<Layout>
  <!-- ===== NAVBAR ===== -->
  <nav class="fixed top-0 right-0 left-0 z-50 bg-white/90 backdrop-blur-md shadow-sm">
    <div class="max-w-6xl mx-auto px-6 py-3 flex items-center justify-between">
      <img src="/logo.png" alt="מירי קרליץ" class="h-12 w-auto" />
      <ul class="hidden md:flex gap-8 text-brand-dark font-sans text-sm font-semibold">
        <li><a href="#gallery"       class="hover:text-brand-red transition-colors">גלריה</a></li>
        <li><a href="#testimonials"  class="hover:text-brand-red transition-colors">המלצות</a></li>
        <li><a href="#about"         class="hover:text-brand-red transition-colors">קצת עליי</a></li>
        <li><a href="#contact"       class="hover:text-brand-red transition-colors">צור קשר</a></li>
      </ul>
      <a
        href="#contact"
        class="bg-brand-red text-white text-sm font-bold px-5 py-2 rounded-full hover:bg-brand-redDark transition-all shadow-md hover:shadow-lg"
      >
        רוצה לשמוע עוד ♥
      </a>
    </div>
  </nav>

  <!-- ===== HERO ===== -->
  <section
    id="hero"
    class="relative min-h-screen flex flex-col items-center justify-center text-center overflow-hidden"
    style="background: linear-gradient(135deg, #C41E3A 0%, #9B1530 40%, #2D2020 100%);"
  >
    <!-- Decorative hearts background -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
      <span class="absolute text-white/10 text-[200px] top-[-40px] right-[-30px] select-none">♥</span>
      <span class="absolute text-white/10 text-[150px] bottom-[-20px] left-[-20px] select-none">♥</span>
      <span class="absolute text-white/5  text-[100px] top-1/3 left-1/4 select-none">♥</span>
      <span class="absolute text-white/5  text-[80px]  bottom-1/4 right-1/3 select-none">♥</span>
      <!-- Pink circles -->
      <div class="absolute w-96 h-96 rounded-full bg-brand-pinkMid/20 -top-20 -left-20 blur-3xl"></div>
      <div class="absolute w-80 h-80 rounded-full bg-brand-blue/10   -bottom-10 -right-10 blur-3xl"></div>
    </div>

    <div class="relative z-10 px-6 flex flex-col items-center gap-6">
      <!-- Logo -->
      <div class="reveal">
        <img
          src="/logo.png"
          alt="מירי קרליץ"
          class="h-28 md:h-36 w-auto drop-shadow-2xl"
        />
      </div>

      <!-- Tagline -->
      <div class="reveal reveal-delay-1">
        <p class="text-brand-pinkMid text-lg md:text-xl font-sans tracking-widest uppercase">
          Miri Karelitz Photography
        </p>
      </div>

      <!-- Quote -->
      <div class="reveal reveal-delay-2 max-w-xl">
        <h1 class="text-white text-2xl md:text-4xl font-serif leading-relaxed"
            style="font-family: 'Noto Serif Hebrew', serif;">
          "כשתמונה ורגש נפגשים,<br/>זה כבר סיפור אחר..."
        </h1>
      </div>

      <!-- Sub text -->
      <div class="reveal reveal-delay-3">
        <p class="text-white/75 text-base md:text-lg font-sans">
          צילומי בת מצווה ✦ ילדים ✦ משפחה
        </p>
      </div>

      <!-- CTA -->
      <div class="reveal reveal-delay-4">
        <a
          href="#contact"
          class="inline-block mt-2 bg-white text-brand-red text-base md:text-lg font-bold px-10 py-4 rounded-full shadow-2xl hover:bg-brand-pink hover:scale-105 transition-all duration-300"
        >
          רוצה לשמוע עוד ♥
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/50">
      <span class="text-xs font-sans tracking-widest">גלול למטה</span>
      <div class="w-0.5 h-10 bg-white/30 animate-bounce mx-auto"></div>
    </div>
  </section>

  <!-- ===== GALLERY ===== -->
  <section id="gallery" class="py-20 px-4 bg-white">
    <div class="max-w-6xl mx-auto">
      <!-- Section header -->
      <div class="text-center mb-12 reveal">
        <span class="text-brand-red text-3xl">♥</span>
        <h2 class="text-3xl md:text-4xl font-serif text-brand-dark mt-2"
            style="font-family: 'Noto Serif Hebrew', serif;">
          הגלריה שלי
        </h2>
        <p class="text-brand-dark/60 mt-3 text-base font-sans">
          כל תמונה מספרת סיפור משלה
        </p>
        <div class="w-16 h-1 bg-brand-red rounded-full mx-auto mt-4"></div>
      </div>

      <!-- Category tabs -->
      <div class="flex flex-wrap justify-center gap-3 mb-10 reveal">
        {categories.map((cat, i) => (
          <button
            data-tab={cat.id}
            class={`gallery-tab px-5 py-2 rounded-full text-sm font-bold border-2 transition-all duration-200 ${i === 0 ? 'active bg-brand-red text-white border-brand-red' : 'bg-white text-brand-red border-brand-red hover:bg-brand-pink'}`}
          >
            {cat.label}
          </button>
        ))}
      </div>

      <!-- Gallery grids -->
      {categories.map((cat) => (
        <div
          id={`grid-${cat.id}`}
          class={`gallery-grid gap-3 ${cat.id === 'albums' ? 'grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4' : 'grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-6 gap-2'} ${cat.id !== 'bat-mitzva' ? 'hidden' : ''}`}
        >
          {galleryImages[cat.id].map((img) => (
            cat.id === 'albums'
            ? (
              <div class="group relative overflow-hidden rounded-xl shadow-sm bg-white cursor-pointer flex items-center justify-center p-1">
                <img
                  src={img.src}
                  alt={img.alt}
                  class="w-full h-auto object-contain transition-transform duration-500 group-hover:scale-105 rounded-lg"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-brand-red/0 group-hover:bg-brand-red/20 transition-all duration-300 flex items-center justify-center rounded-xl">
                  <span class="text-white text-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-300 drop-shadow-lg">♥</span>
                </div>
              </div>
            )
            : (
              <div class="group relative overflow-hidden rounded-xl shadow-sm aspect-square bg-brand-pink cursor-pointer">
                <img
                  src={img.src}
                  alt={img.alt}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-brand-red/0 group-hover:bg-brand-red/40 transition-all duration-300 flex items-center justify-center">
                  <span class="text-white text-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-300 drop-shadow-lg">♥</span>
                </div>
              </div>
            )
          ))}
        </div>
      ))}
    </div>
  </section>

  <!-- ===== TESTIMONIALS ===== -->
  <section id="testimonials" class="py-20 px-4" style="background: linear-gradient(180deg, #FEF6F7 0%, #FADADD 100%);">
    <div class="max-w-6xl mx-auto">
      <!-- Header -->
      <div class="text-center mb-12 reveal">
        <span class="text-brand-red text-3xl">♥</span>
        <h2 class="text-3xl md:text-4xl font-serif text-brand-dark mt-2"
            style="font-family: 'Noto Serif Hebrew', serif;">
          מה אומרות הלקוחות
        </h2>
        <p class="text-brand-dark/60 mt-3 text-base font-sans">
          המלצות מהלב, ממשפחות שסמכו עליי
        </p>
        <div class="w-16 h-1 bg-brand-red rounded-full mx-auto mt-4"></div>
      </div>

      <!-- Decorative heart -->
      <div class="text-center text-brand-pinkDeep text-5xl mb-8 animate-pulse" aria-hidden="true">♥</div>

      <!-- Initial testimonials -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="testimonials-initial">
        {testimonialsInitial.map((t, i) => (
          <div class={`reveal reveal-delay-${(i % 4) + 1} bg-white rounded-3xl shadow-lg overflow-hidden border border-brand-pink hover:shadow-xl hover:-translate-y-1 transition-all duration-300`}>
            <div class="bg-gradient-to-r from-brand-red to-brand-redLight p-4 flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-white/20 flex items-center justify-center text-white font-bold text-lg">
                {t.name[0]}
              </div>
              <div>
                <p class="text-white font-bold text-sm">{t.name}</p>
                <p class="text-white/75 text-xs">{t.type}</p>
              </div>
              <span class="mr-auto text-white text-xl">♥</span>
            </div>
            <div class="p-2">
              <img
                src={`/testimonials/${t.file}`}
                alt={`המלצה של ${t.name}`}
                class="w-full rounded-xl"
                loading="lazy"
              />
            </div>
          </div>
        ))}
      </div>

      <!-- Extra testimonials (hidden initially) -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-6 hidden" id="testimonials-extra">
        {testimonialsExtra.map((t, i) => (
          <div class={`bg-white rounded-3xl shadow-lg overflow-hidden border border-brand-pink hover:shadow-xl hover:-translate-y-1 transition-all duration-300`}>
            <div class="bg-gradient-to-r from-brand-pinkDeep to-brand-red p-4 flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-white/20 flex items-center justify-center text-white font-bold text-lg">
                {t.name[0]}
              </div>
              <div>
                <p class="text-white font-bold text-sm">{t.name}</p>
                <p class="text-white/75 text-xs">{t.type}</p>
              </div>
              <span class="mr-auto text-white text-xl">♥</span>
            </div>
            <div class="p-2">
              <img
                src={`/testimonials/${t.file}`}
                alt={`המלצה של ${t.name}`}
                class="w-full rounded-xl"
                loading="lazy"
              />
            </div>
          </div>
        ))}
      </div>

      <!-- Show more button -->
      <div class="text-center mt-10 reveal">
        <button
          id="show-more-btn"
          class="bg-brand-red text-white font-bold px-10 py-3 rounded-full shadow-lg hover:bg-brand-redDark hover:scale-105 transition-all duration-300"
        >
          עוד המלצות ♥
        </button>
      </div>
    </div>
  </section>

  <!-- ===== ABOUT ===== -->
  <section id="about" class="py-20 px-4 bg-white overflow-hidden">
    <div class="max-w-6xl mx-auto">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <!-- Image side -->
        <div class="reveal relative order-2 md:order-1">
          <!-- Decorative background shapes -->
          <div class="absolute -top-6 -right-6 w-48 h-48 rounded-full bg-brand-pink opacity-50 -z-10"></div>
          <div class="absolute -bottom-6 -left-6 w-32 h-32 rounded-full bg-brand-blue opacity-40 -z-10"></div>

          <div class="relative rounded-3xl overflow-hidden shadow-2xl border-4 border-brand-pink aspect-[3/4] bg-brand-cream">
            <!-- Photographer placeholder with brand styling -->
            <div class="w-full h-full flex flex-col items-center justify-center bg-gradient-to-br from-brand-pink via-brand-cream to-brand-blue p-8">
              <div class="w-40 h-40 rounded-full bg-brand-red/20 flex items-center justify-center mb-6 border-4 border-brand-red/30">
                <span class="text-7xl">📷</span>
              </div>
              <img src="/logo.png" alt="מירי קרליץ" class="h-20 w-auto opacity-80" />
              <p class="text-brand-red font-bold mt-4 text-center font-sans">
                "סיפור פוטוגני"
              </p>
            </div>
          </div>

          <!-- Floating heart badge -->
          <div class="absolute -bottom-4 -right-4 bg-brand-red text-white rounded-2xl px-4 py-3 shadow-xl text-center">
            <p class="text-2xl font-bold">♥</p>
            <p class="text-xs font-sans font-bold leading-tight">לוכדת<br/>רגעים</p>
          </div>
        </div>

        <!-- Text side -->
        <div class="order-1 md:order-2 space-y-6">
          <div class="reveal">
            <span class="text-brand-red text-3xl">♥</span>
            <h2 class="text-3xl md:text-4xl font-serif text-brand-dark mt-2"
                style="font-family: 'Noto Serif Hebrew', serif;">
              קצת עליי
            </h2>
            <div class="w-16 h-1 bg-brand-red rounded-full mt-4"></div>
          </div>

          <div class="reveal reveal-delay-1 space-y-4 text-brand-dark/80 font-sans leading-relaxed text-base">
            <p>
              שלום! אני מירי קרליץ, צלמת המתמחה בצילומי <strong class="text-brand-red">בת מצווה, ילדים ומשפחה</strong>.
              אני מאמינה שכל משפחה היא יצירת אמנות בפני עצמה, וכל ילד הוא עולם ומלואו.
            </p>
            <p>
              הגישה שלי היא <strong class="text-brand-red">חמה, סבלנית ויצירתית</strong> —
              אני לוקחת את הזמן להכיר את הילדים ולגרום להם להרגיש בנוח לפני שלוחצת על התריס.
              התוצאה? תמונות אמיתיות, טבעיות, שמספרות את הסיפור שלכם.
            </p>
            <p>
              כל צילום מתוכנן בקפידה — מבחירת הלוקיישן, דרך תיאום הביגוד,
              ועד לעריכה הסופית. אני מביאה <strong class="text-brand-red">לב שלם</strong> לכל סשן צילום.
            </p>
          </div>

          <!-- Values cards -->
          <div class="reveal reveal-delay-2 grid grid-cols-3 gap-3">
            {[
              { icon: '♥', title: 'חום וסבלנות', desc: 'גישה אישית לכל ילד' },
              { icon: '✨', title: 'מקצועיות', desc: 'ציוד מתקדם ועריכה מושלמת' },
              { icon: '📷', title: 'יצירתיות', desc: 'זוויות ייחודיות וסיפור שלכם' },
            ].map(v => (
              <div class="bg-brand-cream rounded-2xl p-4 text-center border border-brand-pink hover:border-brand-red transition-colors">
                <div class="text-2xl mb-2">{v.icon}</div>
                <p class="text-brand-red font-bold text-sm">{v.title}</p>
                <p class="text-brand-dark/60 text-xs mt-1">{v.desc}</p>
              </div>
            ))}
          </div>

          <!-- CTA -->
          <div class="reveal reveal-delay-3">
            <a
              href="#contact"
              class="inline-block bg-brand-red text-white font-bold px-8 py-3 rounded-full shadow-lg hover:bg-brand-redDark hover:scale-105 transition-all duration-300"
            >
              בואו נכיר! ♥
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CONTACT FORM ===== -->
  <section id="contact" class="py-20 px-4" style="background: linear-gradient(135deg, #C41E3A 0%, #9B1530 100%);">
    <div class="max-w-2xl mx-auto">
      <!-- Header -->
      <div class="text-center mb-10 reveal">
        <span class="text-white/60 text-3xl">♥</span>
        <h2 class="text-3xl md:text-4xl font-serif text-white mt-2"
            style="font-family: 'Noto Serif Hebrew', serif;">
          צור קשר
        </h2>
        <p class="text-white/70 mt-3 text-base font-sans">
          נשמח לשמוע ממכם ולתכנן ביחד את הסשן המושלם
        </p>
        <div class="w-16 h-1 bg-white/40 rounded-full mx-auto mt-4"></div>
      </div>

      <!-- Contact card -->
      <div class="reveal bg-white/10 backdrop-blur-md rounded-3xl p-8 shadow-2xl border border-white/20">
        <!-- Contact info -->
        <div class="flex flex-wrap justify-center gap-6 mb-8 text-white text-sm font-sans">
          <a href="tel:0533190561" class="flex items-center gap-2 hover:text-brand-pink transition-colors">
            <span class="text-xl">📞</span>
            <span class="font-bold">053-319-0561</span>
          </a>
          <a href="mailto:mirizilum@gmail.com" class="flex items-center gap-2 hover:text-brand-pink transition-colors">
            <span class="text-xl">✉️</span>
            <span class="font-bold">mirizilum@gmail.com</span>
          </a>
        </div>

        <!-- Form -->
        <form id="contact-form" class="space-y-4" novalidate>
          <div>
            <label class="block text-white/80 text-sm font-sans mb-2 font-semibold" for="name">
              שם מלא *
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              placeholder="הכניסי את שמך המלא"
              class="w-full bg-white/20 border border-white/30 rounded-2xl px-5 py-3 text-white placeholder-white/50 font-sans focus:outline-none focus:border-white focus:bg-white/30 transition-all"
            />
          </div>

          <div>
            <label class="block text-white/80 text-sm font-sans mb-2 font-semibold" for="phone">
              טלפון *
            </label>
            <input
              type="tel"
              id="phone"
              name="phone"
              required
              placeholder="050-000-0000"
              class="w-full bg-white/20 border border-white/30 rounded-2xl px-5 py-3 text-white placeholder-white/50 font-sans focus:outline-none focus:border-white focus:bg-white/30 transition-all"
            />
          </div>

          <div>
            <label class="block text-white/80 text-sm font-sans mb-2 font-semibold" for="email">
              אימייל
            </label>
            <input
              type="email"
              id="email"
              name="email"
              placeholder="your@email.com"
