---
interface Props { title?: string; }
const { title = 'מירי קרליץ | צלמת | סיפור פוטוגני' } = Astro.props;
---
<!doctype html>
<html lang="he" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Heebo:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <script src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --red:        #C41E3A;
      --red-dark:   #9B1530;
      --red-light:  #E84060;
      --pink:       #FADADD;
      --pink-mid:   #FFB3C6;
      --pink-deep:  #E8839A;
      --pink-light: #FFF0F3;
      --cream:      #FFFBFC;
      --blue:       #C5DCF0;
      --dark:       #3D1020;
      --text:       #2D1520;
      --muted:      #9E7A82;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Heebo', sans-serif;
      background: var(--cream);
      color: var(--text);
      direction: rtl;
      overflow-x: hidden;
      cursor: none;
    }
    @media (pointer: coarse) { body { cursor: auto; } }

    /* ── SCROLLBAR ── */
    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-track { background: var(--cream); }
    ::-webkit-scrollbar-thumb { background: linear-gradient(var(--red), var(--pink-mid)); border-radius: 4px; }

    /* ── SCROLL PROGRESS ── */
    #scroll-progress {
      position: fixed; top: 0; left: 0;
      height: 3px; width: 0%;
      background: linear-gradient(90deg, var(--red), var(--pink-mid), var(--red));
      background-size: 200% auto;
      animation: gradMove 3s linear infinite;
      z-index: 9999;
      box-shadow: 0 0 10px var(--red);
      transition: width 0.08s linear;
    }
    @keyframes gradMove { to { background-position: -200% center; } }

    /* ── CURSOR ── */
    #cursor-dot, #cursor-ring {
      position: fixed; pointer-events: none; z-index: 9998;
      transform: translate(-50%, -50%);
    }
    #cursor-dot {
      width: 8px; height: 8px;
      background: var(--red);
      border-radius: 50%;
    }
    #cursor-ring {
      width: 38px; height: 38px;
      border: 1.5px solid var(--red);
      border-radius: 50%;
      transition: width .25s ease, height .25s ease, border-color .25s ease;
    }
    body.cursor-hover #cursor-ring { width: 56px; height: 56px; border-color: var(--red-light); }
    @media (pointer: coarse) { #cursor-dot, #cursor-ring { display: none; } }

    /* ── LIGHTBOX ── */
    #lightbox {
      position: fixed; inset: 0;
      background: rgba(20,5,10,0.94);
      backdrop-filter: blur(12px);
      z-index: 9000;
      display: flex; align-items: center; justify-content: center;
      opacity: 0; pointer-events: none;
      transition: opacity .35s ease;
      padding: 20px;
    }
    #lightbox.open { opacity: 1; pointer-events: all; }
    #lightbox-img {
      max-width: 92vw; max-height: 86vh;
      object-fit: contain; border-radius: 16px;
      box-shadow: 0 40px 120px rgba(0,0,0,.7);
      transform: scale(.88);
      transition: transform .4s cubic-bezier(.34,1.56,.64,1), opacity .2s;
    }
    #lightbox.open #lightbox-img { transform: scale(1); }
    #lightbox-close, #lightbox-prev, #lightbox-next {
      position: absolute;
      width: 46px; height: 46px;
      background: rgba(255,255,255,.12);
      border: 1px solid rgba(255,255,255,.2);
      border-radius: 50%; cursor: pointer;
      color: #fff; font-size: 20px;
      display: flex; align-items: center; justify-content: center;
      backdrop-filter: blur(6px);
      transition: background .2s, transform .2s;
    }
    #lightbox-close { top: 18px; left: 18px; font-size: 16px; }
    #lightbox-close:hover { background: var(--red); transform: rotate(90deg); }
    #lightbox-prev  { top: 50%; transform: translateY(-50%); right: 18px; }
    #lightbox-next  { top: 50%; transform: translateY(-50%); left:  18px; }
    #lightbox-prev:hover, #lightbox-next:hover {
      background: var(--red);
      transform: translateY(-50%) scale(1.1);
    }

    /* ── REVEAL ANIMATIONS ── */
    .reveal, .reveal-left, .reveal-right, .reveal-scale, .reveal-blur {
      transition-property: opacity, transform, filter;
      transition-timing-function: cubic-bezier(.25,.46,.45,.94);
      transition-duration: .85s;
    }
    .reveal        { opacity:0; transform: translateY(44px); }
    .reveal-left   { opacity:0; transform: translateX(54px); }
    .reveal-right  { opacity:0; transform: translateX(-54px); }
    .reveal-scale  { opacity:0; transform: scale(.82); transition-timing-function: cubic-bezier(.34,1.56,.64,1); }
    .reveal-blur   { opacity:0; filter: blur(14px); transform: translateY(20px); }
    .reveal.visible, .reveal-left.visible, .reveal-right.visible,
    .reveal-scale.visible, .reveal-blur.visible {
      opacity:1; transform: none; filter: none;
    }
    .d1 { transition-delay:.08s; }
    .d2 { transition-delay:.18s; }
    .d3 { transition-delay:.28s; }
    .d4 { transition-delay:.40s; }
    .d5 { transition-delay:.52s; }

    /* ── FLOATING HEARTS ── */
    .fheart {
      position: absolute; pointer-events: none; user-select: none;
      opacity: 0; animation: floatUp linear infinite;
    }
    @keyframes floatUp {
      0%   { transform: translateY(0) rotate(-10deg) scale(1); opacity:0; }
      8%   { opacity: .9; }
      85%  { opacity:.4; }
      100% { transform: translateY(-115vh) rotate(30deg) scale(.4); opacity:0; }
    }

    /* ── MARQUEE ── */
    .marquee-wrap { overflow: hidden; white-space: nowrap; }
    .marquee-inner { display: inline-flex; gap: 0; animation: marquee 28s linear infinite; }
    .marquee-inner:hover { animation-play-state: paused; }
    @keyframes marquee { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }

    /* ── RIPPLE ── */
    .btn-ripple { position: relative; overflow: hidden; }
    .ripple-circle {
      position: absolute; border-radius: 50%;
      background: rgba(255,255,255,.35);
      transform: scale(0); animation: ripAnim .65s linear;
      pointer-events: none;
    }
    @keyframes ripAnim { to { transform: scale(5); opacity: 0; } }

    /* ── GALLERY STAGGER ── */
    .gitem { opacity:0; transform: translateY(22px) scale(.96); transition: opacity .45s ease, transform .45s ease; }
    .gitem.in { opacity:1; transform: none; }

    /* ── HEARTBEAT ── */
    @keyframes heartbeat {
      0%,100%{ transform:scale(1); }
      14%    { transform:scale(1.2); }
      28%    { transform:scale(1); }
      42%    { transform:scale(1.1); }
    }

    /* ── CAROUSEL ── */
    .carousel-track {
      display: flex; gap: 18px;
      cursor: grab; user-select: none;
    }
    .carousel-track:active { cursor: grabbing; }
    .carousel-track > * { flex-shrink: 0; }
  </style>
</head>
<body>
  <div id="scroll-progress"></div>
  <div id="cursor-dot"></div>
  <div id="cursor-ring"></div>

  <div id="lightbox">
    <button id="lightbox-close" aria-label="סגור">✕</button>
    <button id="lightbox-prev"  aria-label="הקודם">›</button>
    <img id="lightbox-img" src="" alt="" />
    <button id="lightbox-next"  aria-label="הבא">‹</button>
  </div>

  <slot />

  <script>
    /* SCROLL PROGRESS */
    const prog = document.getElementById('scroll-progress');
    const updateProg = () => {
      const pct = window.scrollY / (document.body.scrollHeight - window.innerHeight) * 100;
      if (prog) prog.style.width = pct + '%';
    };
    window.addEventListener('scroll', updateProg, { passive: true });

    /* CUSTOM CURSOR */
    const dot  = document.getElementById('cursor-dot');
    const ring = document.getElementById('cursor-ring');
    let mx=0, my=0, rx=0, ry=0;
    window.addEventListener('mousemove', e => { mx=e.clientX; my=e.clientY; }, { passive:true });
    const tickCursor = () => {
      rx += (mx-rx)*.15; ry += (my-ry)*.15;
      if(dot)  { dot.style.left=mx+'px';  dot.style.top=my+'px'; }
      if(ring) { ring.style.left=rx+'px'; ring.style.top=ry+'px'; }
      requestAnimationFrame(tickCursor);
    };
    tickCursor();
    document.querySelectorAll('a,button').forEach(el => {
      el.addEventListener('mouseenter', () => document.body.classList.add('cursor-hover'));
      el.addEventListener('mouseleave', () => document.body.classList.remove('cursor-hover'));
    });

    /* REVEAL OBSERVER */
    const obs = new IntersectionObserver(
      entries => entries.forEach(e => { if(e.isIntersecting) e.target.classList.add('visible'); }),
      { threshold: 0.1 }
    );
    document.querySelectorAll('.reveal,.reveal-left,.reveal-right,.reveal-scale,.reveal-blur')
            .forEach(el => obs.observe(el));

    /* RIPPLE */
    document.querySelectorAll('.btn-ripple').forEach(btn => {
      btn.addEventListener('click', (e: any) => {
        const r = btn.getBoundingClientRect();
        const c = document.createElement('span');
        const sz = Math.max(r.width, r.height);
        c.className = 'ripple-circle';
        c.style.cssText = `width:${sz}px;height:${sz}px;left:${e.clientX-r.left-sz/2}px;top:${e.clientY-r.top-sz/2}px`;
        btn.appendChild(c);
        setTimeout(() => c.remove(), 700);
      });
    });

    /* LIGHTBOX */
    const lb    = document.getElementById('lightbox') as HTMLElement;
    const lbImg = document.getElementById('lightbox-img') as HTMLImageElement;
    let lbAll: string[] = [], lbIdx = 0;

    function openLB(src: string, all: string[], idx: number) {
      lbAll=all; lbIdx=idx; lbImg.src=src;
      lb.classList.add('open'); document.body.style.overflow='hidden';
    }
    function closeLB() { lb.classList.remove('open'); document.body.style.overflow=''; }
    function navLB(d: number) {
      lbIdx=(lbIdx+d+lbAll.length)%lbAll.length;
      lbImg.style.opacity='0';
      setTimeout(()=>{ lbImg.src=lbAll[lbIdx]; lbImg.style.opacity='1'; }, 160);
    }
    lbImg.style.transition='opacity .16s';
    document.getElementById('lightbox-close')?.addEventListener('click', closeLB);
    document.getElementById('lightbox-prev') ?.addEventListener('click', ()=>navLB(1));
    document.getElementById('lightbox-next') ?.addEventListener('click', ()=>navLB(-1));
    lb.addEventListener('click', e => { if(e.target===lb) closeLB(); });
    document.addEventListener('keydown', e => {
      if(!lb.classList.contains('open')) return;
      if(e.key==='Escape')     closeLB();
      if(e.key==='ArrowRight') navLB(1);
      if(e.key==='ArrowLeft')  navLB(-1);
    });
    (window as any).openLB = openLB;
  </script>
</body>
</html>
